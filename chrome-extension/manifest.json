{
  "manifest_version": 3,
  "name": "视频倍速时长",
  "version": "0.1.0",
  "description": "在网页视频上显示原时长、当前倍速和折算后的观看时长。",
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
